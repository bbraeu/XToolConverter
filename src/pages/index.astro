---
import Layout from "../layouts/Layout.astro";
import Converter from "../components/Converter";
import { OPERATION_COLORS } from "../lib/dxf";

const PAYPAL_DONATE_URL = "https://www.paypal.com/donate/?business=TLNAVJR8TMALY&no_recurring=0&currency_code=EUR";

const operations = [
    OPERATION_COLORS.FILL_VECTOR_ENGRAVING!,
    OPERATION_COLORS.VECTOR_ENGRAVING!,
    OPERATION_COLORS.VECTOR_CUTTING!
];

const features = [
    {
        icon: "M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z",
        title: "100% private",
        text: "Your designs never leave your computer. Parsing, conversion and DXF generation all run locally in your browser — no upload, no server, no account."
    },
    {
        icon: "M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3",
        title: "Operations preserved",
        text: "Surface engraving, line engraving and cutting stay separate: as colours in DXF/SVG — or natively assigned layers in a Falcon Design Space (.fds) project, no manual setup after import."
    },
    {
        icon: "M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42",
        title: "0.01 mm precision",
        text: "Bezier curves are adaptively flattened to polylines at a hundredth of a millimetre — far below any laser spot size, readable by every CAM tool."
    },
    {
        icon: "M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5",
        title: "Free & open source",
        text: "No paywall, no watermark, no limits. The full source code is on GitHub — inspect it, fork it, improve it."
    }
];

const steps = [
    { n: "01", title: "Export from xTool Creative Space", text: "Save your project as a regular .xcs file — that's it, no special export needed." },
    { n: "02", title: "Drop it into the converter", text: "Get an instant colour-coded preview of every canvas: engravings, line work and cuts at a glance." },
    { n: "03", title: "Download in your format", text: "DXF for any CAM software, a native .fds project for Falcon Design Space (operations pre-assigned), or SVG." }
];
---

<Layout
    title="XCS Converter — xTool .xcs to DXF, Falcon Design Space & SVG"
    description="Free converter for xTool Creative Space .xcs files to DXF, native Falcon Design Space projects (.fds) and SVG. Keeps surface engraving, line engraving and cutting separated. 100% in-browser."
>
    <!-- ───────────────────────── Hero ───────────────────────── -->
    <section class="relative flex min-h-[92svh] flex-col items-center justify-center px-4 pt-28 pb-16 text-center">
        <div class="reveal is-visible">
            <span class="glass inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-xs font-medium text-cyan-200">
                <span class="size-1.5 animate-pulse-glow rounded-full bg-cyan-300"></span>
                100% in-browser · nothing gets uploaded
            </span>
        </div>

        <h1 class="reveal is-visible mt-7 max-w-4xl text-5xl font-black tracking-tight text-white sm:text-7xl" style="--reveal-delay: 80ms">
            Set your <span class="text-gradient">.xcs files</span> free.
        </h1>

        <p class="reveal is-visible mt-6 max-w-2xl text-lg text-slate-400 sm:text-xl" style="--reveal-delay: 160ms">
            Convert xTool Creative Space projects to clean, colour-coded <strong class="text-slate-200">DXF</strong>,
            native <strong class="text-slate-200">Falcon Design Space</strong> projects or <strong class="text-slate-200">SVG</strong> —
            with surface engraving, line engraving and cutting preserved as separate operations.
        </p>

        <div class="reveal is-visible mt-9 flex flex-wrap items-center justify-center gap-4" style="--reveal-delay: 240ms">
            <a href="#converter"
               class="rounded-xl bg-linear-to-r from-cyan-500 to-violet-500 px-7 py-3.5 font-semibold text-white shadow-xl shadow-violet-500/30 transition hover:brightness-110 active:scale-95">
                Convert a file now
            </a>
            <a href="#how" class="glass rounded-xl px-7 py-3.5 font-semibold text-slate-200 transition hover:bg-white/10">
                How it works
            </a>
        </div>

        <!-- Operation colour chips -->
        <div class="reveal is-visible mt-14 flex flex-wrap items-center justify-center gap-3" style="--reveal-delay: 320ms">
            {operations.map(op => (
                <span class="glass flex items-center gap-2 rounded-full px-4 py-2 text-sm text-slate-300">
                    <span class="size-3 rounded-full shadow-[0_0_12px_2px_var(--tw-shadow-color)]" style={`background:${op.css}; --tw-shadow-color:${op.css}66`}></span>
                    {op.name}
                </span>
            ))}
        </div>

        <!-- Laser divider -->
        <div class="relative mt-16 h-px w-[min(56rem,90%)] overflow-hidden bg-white/10" aria-hidden="true">
            <div class="laser-beam !w-24 !bg-linear-to-r !from-transparent !via-rose-500 !to-transparent"></div>
        </div>
    </section>

    <!-- ─────────────────────── Converter ─────────────────────── -->
    <section id="converter" class="relative px-4 py-20">
        <div class="mx-auto w-[min(72rem,100%)]">
            <div class="reveal text-center">
                <h2 class="text-3xl font-bold text-white sm:text-4xl">Drop it like it's <span class="text-gradient">hot</span> 🔥</h2>
                <p class="mx-auto mt-3 max-w-xl text-slate-400">Select an .xcs project below — every canvas becomes a preview tab with its own DXF download.</p>
            </div>
            <div class="reveal mt-10" style="--reveal-delay: 120ms">
                <Converter client:load />
            </div>
        </div>
    </section>

    <!-- ─────────────────────── Features ─────────────────────── -->
    <section id="features" class="relative px-4 py-20">
        <div class="mx-auto w-[min(72rem,100%)]">
            <div class="reveal text-center">
                <h2 class="text-3xl font-bold text-white sm:text-4xl">Why this converter?</h2>
            </div>
            <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
                {features.map((f, i) => (
                    <article class="glass glow-card reveal rounded-2xl p-6" style={`--reveal-delay: ${i * 90}ms`}>
                        <div class="grid size-12 place-items-center rounded-xl bg-linear-to-br from-cyan-400/20 to-violet-500/20 ring-1 ring-white/10">
                            <svg class="size-6 text-cyan-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
                                <path stroke-linecap="round" stroke-linejoin="round" d={f.icon} />
                            </svg>
                        </div>
                        <h3 class="mt-5 text-lg font-semibold text-white">{f.title}</h3>
                        <p class="mt-2 text-sm leading-relaxed text-slate-400">{f.text}</p>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <!-- ────────────────────── How it works ────────────────────── -->
    <section id="how" class="relative px-4 py-20">
        <div class="mx-auto w-[min(72rem,100%)]">
            <div class="reveal text-center">
                <h2 class="text-3xl font-bold text-white sm:text-4xl">Three steps. <span class="text-gradient">Zero uploads.</span></h2>
            </div>
            <ol class="mt-12 grid gap-5 lg:grid-cols-3">
                {steps.map((s, i) => (
                    <li class="glass glow-card reveal relative overflow-hidden rounded-2xl p-7" style={`--reveal-delay: ${i * 110}ms`}>
                        <span class="text-gradient absolute -top-3 -right-1 text-8xl font-black opacity-20 select-none" aria-hidden="true">{s.n}</span>
                        <span class="text-sm font-bold tracking-widest text-cyan-300">STEP {s.n}</span>
                        <h3 class="mt-3 text-lg font-semibold text-white">{s.title}</h3>
                        <p class="mt-2 text-sm leading-relaxed text-slate-400">{s.text}</p>
                    </li>
                ))}
            </ol>
            <p class="reveal mx-auto mt-8 max-w-2xl text-center text-sm text-slate-500" style="--reveal-delay: 200ms">
                Note: DXF/SVG carry geometry and colours, not laser parameters — assign power &amp; speed per colour once in your laser software.
                The .fds export pre-assigns the operation per layer; power &amp; speed still come from your material settings.
                This is a beta-grade tool; heavily skewed shapes may not convert perfectly.
            </p>
        </div>
    </section>

    <!-- ──────────────────── Credits + Donate ──────────────────── -->
    <section id="credits" class="relative px-4 py-20 pb-28">
        <div class="mx-auto w-[min(72rem,100%)]">
            <div class="reveal text-center">
                <h2 class="text-3xl font-bold text-white sm:text-4xl">Credits &amp; support</h2>
            </div>
            <div class="mt-12 grid gap-5 lg:grid-cols-3">
                <article class="glass glow-card reveal rounded-2xl p-7">
                    <p class="text-sm font-bold tracking-widest text-cyan-300">MAINTAINED BY</p>
                    <h3 class="mt-3 text-xl font-semibold text-white">bbraeu</h3>
                    <p class="mt-2 text-sm leading-relaxed text-slate-400">
                        DXF export engine, operation-type preservation and this redesign.
                    </p>
                    <a href="https://github.com/bbraeu" target="_blank" rel="noopener"
                       class="mt-5 inline-block rounded-lg border border-white/15 px-4 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-400/50 hover:text-white">
                        github.com/bbraeu ↗
                    </a>
                </article>

                <article class="glass glow-card reveal rounded-2xl p-7" style="--reveal-delay: 110ms">
                    <p class="text-sm font-bold tracking-widest text-violet-300">BASED ON</p>
                    <h3 class="mt-3 text-xl font-semibold text-white">XCStoSVG by Daniel Nanovski</h3>
                    <p class="mt-2 text-sm leading-relaxed text-slate-400">
                        The original in-browser .xcs converter this project builds upon. Thank you!
                    </p>
                    <a href="https://nanovsky.github.io/XCStoSVG/" target="_blank" rel="noopener"
                       class="mt-5 inline-block rounded-lg border border-white/15 px-4 py-2 text-sm font-medium text-slate-200 transition hover:border-violet-400/50 hover:text-white">
                        Original project ↗
                    </a>
                </article>

                <article class="glass glow-card reveal rounded-2xl p-7" style="--reveal-delay: 220ms">
                    <p class="text-sm font-bold tracking-widest text-fuchsia-300">SUPPORT</p>
                    <h3 class="mt-3 text-xl font-semibold text-white">Buy the laser a coffee ☕</h3>
                    <p class="mt-2 text-sm leading-relaxed text-slate-400">
                        This tool is free and always will be. If it saved your project, a small donation keeps it running.
                    </p>
                    {PAYPAL_DONATE_URL ? (
                        <a href={PAYPAL_DONATE_URL} target="_blank" rel="noopener"
                           class="mt-5 inline-block rounded-lg bg-linear-to-r from-amber-400 to-orange-500 px-5 py-2.5 text-sm font-semibold text-slate-900 shadow-lg shadow-orange-500/25 transition hover:brightness-110 active:scale-95">
                            Donate via PayPal
                        </a>
                    ) : (
                        <span class="mt-5 inline-block rounded-lg border border-dashed border-white/20 px-5 py-2.5 text-sm text-slate-500">
                            PayPal link coming soon
                        </span>
                    )}
                </article>
            </div>
        </div>
    </section>
</Layout>
