---
import "../styles/global.css";

interface Props {
    title: string;
    description: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const isProd = import.meta.env.PROD;

// Google Analytics 4 Measurement ID ("G-…"). Leave empty to disable analytics
// entirely (no script is loaded). Tracked events: convert_file, DXF_Download,
// FDS_Download, SVG_Download, download_zip — see trackEvent() in lib/util.ts.
// Uses Google Consent Mode v2 (advanced): gtag.js always loads with all
// consent defaults denied; the banner decision is applied via consent update.
const GA_MEASUREMENT_ID = "G-79BWTBS409";
---

<!doctype html>
<html lang="en" class="scroll-pt-24">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.png`} />
    <title>{isProd ? "" : "[DEV] "}{title}</title>

    {isProd && GA_MEASUREMENT_ID && (
        <>
            <!-- Google Consent Mode v2 (advanced). Order matters: the consent
                 defaults MUST be pushed before gtag.js loads, otherwise they
                 are ignored (see developers.google.com/tag-platform/security/guides/consent). -->
            <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
                window.dataLayer = window.dataLayer || [];
                function gtag() { dataLayer.push(arguments); }
                window.gtag = gtag;

                gtag("consent", "default", {
                    ad_storage: "denied",
                    ad_user_data: "denied",
                    ad_personalization: "denied",
                    analytics_storage: "denied"
                });
                gtag("set", "ads_data_redaction", true);

                // Re-apply a previously stored decision before config so the
                // first page_view already runs with the right consent state.
                if (localStorage.getItem("analytics-consent") === "granted") {
                    gtag("consent", "update", { analytics_storage: "granted" });
                }

                gtag("js", new Date());
                gtag("config", GA_MEASUREMENT_ID);
            </script>
            <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
        </>
    )}
</head>
<body class="relative min-h-screen antialiased">
    <!-- Decorative background: blueprint grid + floating gradient blobs -->
    <div class="pointer-events-none fixed inset-0 -z-10" aria-hidden="true">
        <div class="bg-blueprint absolute inset-0"></div>
        <div class="absolute -top-40 -left-40 size-144 rounded-full bg-cyan-500/20 blur-[120px] animate-float-slow"></div>
        <div class="absolute top-1/3 -right-52 size-160 rounded-full bg-violet-600/20 blur-[130px] animate-float-slower"></div>
        <div class="absolute -bottom-64 left-1/3 size-152 rounded-full bg-fuchsia-500/10 blur-[140px] animate-float-slow"></div>
    </div>

    <!-- Nav -->
    <header class="fixed inset-x-0 top-0 z-50">
        <nav class="glass mx-auto mt-4 flex w-[min(72rem,calc(100%-2rem))] items-center justify-between rounded-2xl px-5 py-3">
            <a href={`${base}#top`} class="flex items-center gap-2.5 font-bold text-white">
                <span class="grid size-8 place-items-center rounded-lg bg-linear-to-br from-cyan-400 to-violet-500 text-sm shadow-lg shadow-violet-500/30">⚡</span>
                <span>XTool<span class="text-gradient">Converter</span></span>
            </a>
            <div class="hidden items-center gap-1 sm:flex">
                <a href={`${base}#converter`} class="rounded-lg px-3 py-2 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white">Converter</a>
                <a href={`${base}#features`} class="rounded-lg px-3 py-2 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white">Features</a>
                <a href={`${base}#how`} class="rounded-lg px-3 py-2 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white">How it works</a>
                <a href={`${base}#credits`} class="rounded-lg px-3 py-2 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white">Credits</a>
            </div>
            <a href="https://github.com/bbraeu/XToolConverter" target="_blank" rel="noopener"
               class="rounded-lg border border-white/15 px-3.5 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-400/50 hover:text-white">
                GitHub
            </a>
        </nav>
    </header>

    <main id="top">
        <slot />
    </main>

    <footer class="border-t border-white/5 py-10">
        <div class="mx-auto flex w-[min(72rem,calc(100%-2rem))] flex-col items-center gap-3 text-center">
            <p class="text-sm text-slate-400">
                Built by <a href="https://github.com/bbraeu" target="_blank" rel="noopener" class="font-medium text-slate-200 underline decoration-cyan-400/50 underline-offset-4 transition hover:text-cyan-300">bbraeu</a>
                · based on <a href="https://nanovsky.github.io/XCStoSVG/" target="_blank" rel="noopener" class="font-medium text-slate-200 underline decoration-violet-400/50 underline-offset-4 transition hover:text-violet-300">XCStoSVG by Daniel Nanovski</a>
            </p>
            <p class="text-xs text-slate-500">Files never leave your computer — conversion runs entirely in your browser.</p>
            <button id="cookie-settings" class="text-xs text-slate-500 underline decoration-slate-600 underline-offset-2 transition hover:text-slate-300">
                Cookie settings
            </button>
        </div>
    </footer>

    {isProd && GA_MEASUREMENT_ID && (
        <>
            <!-- Consent banner: drives gtag('consent', 'update') — Consent Mode v2 -->
            <div id="consent-banner" hidden
                 class="glass fixed inset-x-4 bottom-4 z-60 mx-auto max-w-xl rounded-2xl p-5 shadow-2xl shadow-black/50"
                 role="dialog" aria-live="polite" aria-label="Cookie consent">
                <p class="text-sm leading-relaxed text-slate-300">
                    <span class="font-semibold text-white">Analytics?</span>{" "}
                    We'd like to use Google Analytics to understand how the converter is used
                    (page views, which formats get downloaded). Only if you agree are analytics
                    cookies set; if you decline, Google receives at most anonymous, cookieless
                    signals (Google Consent Mode). Your files are never involved either way.
                </p>
                <div class="mt-4 flex flex-wrap gap-3">
                    <button id="consent-accept"
                            class="rounded-lg bg-linear-to-r from-cyan-500 to-violet-500 px-5 py-2 text-sm font-semibold text-white transition hover:brightness-110 active:scale-95">
                        Allow analytics
                    </button>
                    <button id="consent-decline"
                            class="rounded-lg border border-white/20 px-5 py-2 text-sm font-medium text-slate-200 transition hover:border-white/40 hover:text-white">
                        Decline
                    </button>
                </div>
            </div>

            <script is:inline>
                (function () {
                    var KEY = "analytics-consent";
                    var banner = document.getElementById("consent-banner");

                    function choose(value) {
                        localStorage.setItem(KEY, value);
                        banner.hidden = true;
                        window.gtag("consent", "update", {
                            analytics_storage: value === "granted" ? "granted" : "denied"
                        });
                    }

                    var stored = localStorage.getItem(KEY);
                    if (stored !== "granted" && stored !== "denied") banner.hidden = false;

                    document.getElementById("consent-accept").addEventListener("click", function () { choose("granted"); });
                    document.getElementById("consent-decline").addEventListener("click", function () { choose("denied"); });

                    // Footer link: revisit the decision. Revoking downgrades consent
                    // right away and drops the GA cookies so the client id is forgotten.
                    document.getElementById("cookie-settings").addEventListener("click", function () {
                        localStorage.removeItem(KEY);
                        window.gtag("consent", "update", { analytics_storage: "denied" });
                        document.cookie.split(";").forEach(function (c) {
                            var name = c.split("=")[0].trim();
                            if (name.indexOf("_ga") === 0) {
                                document.cookie = name + "=; Max-Age=0; path=/; domain=" + location.hostname;
                                document.cookie = name + "=; Max-Age=0; path=/";
                            }
                        });
                        banner.hidden = false;
                    });
                })();
            </script>
        </>
    )}

    <!-- Scroll reveal -->
    <script>
        const io = new IntersectionObserver(
            entries => {
                for (const e of entries) {
                    if (e.isIntersecting) {
                        e.target.classList.add("is-visible");
                        io.unobserve(e.target);
                    }
                }
            },
            { threshold: 0.12 }
        );
        document.querySelectorAll(".reveal").forEach(el => io.observe(el));
    </script>
</body>
</html>
